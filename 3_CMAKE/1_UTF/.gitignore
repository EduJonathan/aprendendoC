# Diretórios de build (os mais comuns)
build/
build-*/
cmake_build/
cmake-build*/
out/
bin/
dist/
_release/
_debug/
x64/
x86/
Debug/
Release/
MinSizeRel/
RelWithDebInfo/

# Arquivos gerados pelo CMake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CMakePresets.json.user*     # se alguém editar presets localmente
CMakeUserPresets.json       # às vezes é local
compile_commands.json       # útil, mas muitas vezes gerado localmente
CTestTestfile.cmake
DartConfiguration.tcl
Testing/                    # resultados de CTest

# Executáveis e objetos
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.exp
*.ilk
*.pdb
*.i*86
*.s[uo]id

# Outros artefatos de link/compilação
*.lo
*.la
*.lai
*.deps/
*.dirstamp
.deps/
.libs/

# Ferramentas e editores
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
*.sublime-workspace
*.sublime-project

# Logs e temporários
*.log
*.tmp
*.bak
*.backup

# Dependências baixadas manualmente (se não usar submodules / FetchContent / vcpkg / conan)
lib/
libs/
vendor/                 # ← comente se você versiona vendor/
extern/                 # ← comente se versiona extern/

# Se usar CTest + coverage
*.gcda
*.gcno
*.gcov
lcov.info
coverage/
